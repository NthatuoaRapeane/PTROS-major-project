rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== HELPER FUNCTIONS ====================
    function isAuth() {
      return request.auth != null;
    }

    // Read role from the user's Firestore document (roles stored in /users/{uid})
    function getUserRoleFromDoc(uid) {
      return isAuth() ? get(/databases/$(database)/documents/users/$(uid)).data.role : null;
    }

    function isCoordinator() {
      return isAuth() && (
        getUserRoleFromDoc(request.auth.uid) == 'coordinator'
        || getUserRoleFromDoc(request.auth.uid) == 'Coordinator'
        || getUserRoleFromDoc(request.auth.uid) == 'admin'
        || getUserRoleFromDoc(request.auth.uid) == 'Admin'
        || getUserRoleFromDoc(request.auth.uid) == 'super_admin'
      );
    }

    function isCarrier() {
      return isAuth() && (
        getUserRoleFromDoc(request.auth.uid) == 'carrier'
        || getUserRoleFromDoc(request.auth.uid) == 'Carrier'
      );
    }

    function isCustomer() {
      return isAuth() && (
        getUserRoleFromDoc(request.auth.uid) == 'customer'
        || getUserRoleFromDoc(request.auth.uid) == 'Customer'
      );
    }

    function isNumberInRange(value, min, max) {
      return value is number && value >= min && value <= max;
    }

    function isValidVehicleProfile(profile) {
      return profile is map
        && profile.keys().hasAll(['capacityKg', 'speedKmh'])
        && isNumberInRange(profile.capacityKg, 1, 100000)
        && isNumberInRange(profile.speedKmh, 1, 300);
    }

    function isValidBusinessRulesPayload(data) {
      return data.keys().hasAll([
          'pricing',
          'recommendation',
          'locationOfficialThresholds',
          'vehicleProfiles',
          'coordinatorReviewTriggers'
        ])

        && data.pricing is map
        && data.pricing.keys().hasAll([
          'baseValueFallback',
          'distanceRatePerKm',
          'packageValueRate',
          'minimumCharge',
          'activeDeliverySurchargeRate'
        ])
        && isNumberInRange(data.pricing.baseValueFallback, 0, 100000)
        && isNumberInRange(data.pricing.distanceRatePerKm, 0, 10000)
        && isNumberInRange(data.pricing.packageValueRate, 0, 5)
        && isNumberInRange(data.pricing.minimumCharge, 0, 100000)
        && isNumberInRange(data.pricing.activeDeliverySurchargeRate, 0, 5)

        && data.recommendation is map
        && data.recommendation.keys().hasAll([
          'busyStatusPenalty',
          'unknownStatusPenalty',
          'workloadPenaltyPerActive',
          'distancePenaltyPerKm',
          'routePenaltyPerKm',
          'capacityBasePenalty',
          'capacityPenaltyPerKg',
          'ratingBoostPerPoint',
          'maxRatingForBoost',
          'bundleBoost',
          'bundleRouteMaxKm',
          'bundlePickupMaxKm',
          'activeDeliveryCapacityKgImpact',
          'activeDeliveryEtaHoursImpact',
          'minimumEtaHours'
        ])
        && isNumberInRange(data.recommendation.busyStatusPenalty, 0, 10000)
        && isNumberInRange(data.recommendation.unknownStatusPenalty, 0, 10000)
        && isNumberInRange(data.recommendation.workloadPenaltyPerActive, 0, 1000)
        && isNumberInRange(data.recommendation.distancePenaltyPerKm, 0, 1000)
        && isNumberInRange(data.recommendation.routePenaltyPerKm, 0, 1000)
        && isNumberInRange(data.recommendation.capacityBasePenalty, 0, 10000)
        && isNumberInRange(data.recommendation.capacityPenaltyPerKg, 0, 1000)
        && isNumberInRange(data.recommendation.ratingBoostPerPoint, 0, 1000)
        && isNumberInRange(data.recommendation.maxRatingForBoost, 1, 10)
        && isNumberInRange(data.recommendation.bundleBoost, 0, 1000)
        && isNumberInRange(data.recommendation.bundleRouteMaxKm, 0, 1000)
        && isNumberInRange(data.recommendation.bundlePickupMaxKm, 0, 1000)
        && isNumberInRange(data.recommendation.activeDeliveryCapacityKgImpact, 0, 1000)
        && isNumberInRange(data.recommendation.activeDeliveryEtaHoursImpact, 0, 24)
        && isNumberInRange(data.recommendation.minimumEtaHours, 0, 24)

        && data.locationOfficialThresholds is map
        && data.locationOfficialThresholds.keys().hasAll([
          'officialUsageCount',
          'coreOfficialUsageCount'
        ])
        && isNumberInRange(data.locationOfficialThresholds.officialUsageCount, 1, 1000)
        && isNumberInRange(data.locationOfficialThresholds.coreOfficialUsageCount, 1, 1000)
        && data.locationOfficialThresholds.coreOfficialUsageCount >= data.locationOfficialThresholds.officialUsageCount

        && data.vehicleProfiles is map
        && data.vehicleProfiles.keys().hasAll([
          'bicycle',
          'motorcycle',
          'car',
          'pickup',
          'van',
          'truck',
          'unknown'
        ])
        && isValidVehicleProfile(data.vehicleProfiles.bicycle)
        && isValidVehicleProfile(data.vehicleProfiles.motorcycle)
        && isValidVehicleProfile(data.vehicleProfiles.car)
        && isValidVehicleProfile(data.vehicleProfiles.pickup)
        && isValidVehicleProfile(data.vehicleProfiles.van)
        && isValidVehicleProfile(data.vehicleProfiles.truck)
        && isValidVehicleProfile(data.vehicleProfiles.unknown)

        && data.coordinatorReviewTriggers is map
        && data.coordinatorReviewTriggers.keys().hasAll([
          'missingVerifiedCoordinates',
          'noRecommendedCarrierAvailable',
          'carrierCapacityOrAvailabilityRisk',
          'urgentPriorityRequiresConfirmation'
        ])
        && data.coordinatorReviewTriggers.missingVerifiedCoordinates is bool
        && data.coordinatorReviewTriggers.noRecommendedCarrierAvailable is bool
        && data.coordinatorReviewTriggers.carrierCapacityOrAvailabilityRisk is bool
        && data.coordinatorReviewTriggers.urgentPriorityRequiresConfirmation is bool;
    }

    

    // ==================== USERS COLLECTION ====================
    // All user profiles with role, approval status, location, etc.
    match /users/{userId} {
      // Everyone can read their own user document
      allow read: if isAuth() && request.auth.uid == userId;
      
      // Everyone can write to their own document
      allow write: if isAuth() && request.auth.uid == userId;
      
      // COORDINATOR: Read all users (for queries in CreateDelivery, PendingCarriers, LiveMap, etc.)
      allow read: if isCoordinator();
      
      // COORDINATOR: Update any user (approve carriers, reject carriers, update status, etc.)
      allow update: if isCoordinator();

      // CUSTOMER: Read approved carrier profiles (for carrier recommendations during order creation)
      allow read: if isCustomer()
        && resource.data.role in ['carrier', 'Carrier']
        && resource.data.isApproved == true;
    }

    // ==================== DELIVERIES COLLECTION ====================
    // Main delivery records with status, location, OTP, assignments, milestones
    match /deliveries/{deliveryId} {
      
      // GUEST: Public read access for guest tracking (trackingCode must match - verified client-side)
      // Guests can view basic delivery info by knowing the tracking code
      allow read: if request.auth == null;

      // COORDINATOR: Full access - create, read, update all deliveries
      allow read: if isCoordinator();
      allow write: if isCoordinator();
      allow create: if isCoordinator();
      allow update: if isCoordinator();

      // CARRIER: Read deliveries assigned to them
      allow read: if request.auth != null && resource.data.carrierId == request.auth.uid;

      // CARRIER: Read available (pending & unassigned) deliveries
      allow read: if request.auth != null && resource.data.status == 'pending' && resource.data.carrierId == null;

      // CARRIER: Claim a pending, unassigned delivery
      allow update: if isCarrier()
        && resource.data.status == 'pending'
        && resource.data.carrierId == null
        && request.resource.data.carrierId == request.auth.uid
        && request.resource.data.status in ['assigned', 'accepted']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'carrierId',
          'carrierEmail',
          'carrierName',
          'carrierPhone',
          'status',
          'assignedAt',
          'acceptedAt',
          'updatedAt'
        ]);

      // CARRIER: Update an already-assigned own delivery (status, timing, OTP verification, live location)
      allow update: if isCarrier()
        && resource.data.carrierId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'currentLocation',
          'location',
          'otpCode',
          'otpVerified',
          'proofOfDelivery',
          'pickupTime',
          'inTransitTime',
          'outForDeliveryTime',
          'deliveryTime',
          'acceptedAt',
          'updatedAt',
          'locationGraph',
          'statusHistory',
          'routeHistory',
          'routeHistoryMeta',
          'routeHistorySnapshots',
          'routeContext',
          'routeFeedback',
          'routeReviews',
          'optimizationReasons'
        ]);

      // CARRIER: Decline/unassign their currently assigned delivery back to pending
      allow update: if isCarrier()
        && resource.data.carrierId == request.auth.uid
        && request.resource.data.carrierId == null
        && request.resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'carrierId',
          'carrierEmail',
          'carrierName',
          'carrierPhone',
          'assignedAt',
          'updatedAt'
        ]);

      // CUSTOMER: Read own deliveries (order history, tracking)
      allow read: if isCustomer() && resource.data.customerId == request.auth.uid;

      // CUSTOMER: Read active deliveries (scoped by status — for carrier workload calculation in recommendations)
      allow read: if isCustomer()
        && resource.data.status in ['assigned', 'accepted', 'picked_up', 'in_transit', 'out_for_delivery', 'stuck'];

      // CUSTOMER: Create their own delivery/order
      allow create: if isCustomer() && request.resource.data.customerId == request.auth.uid;

      // Route snapshot stream for persistent trip replay
      match /routeSnapshots/{snapshotId} {
        allow read: if isCoordinator()
          || (isAuth() && get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.carrierId == request.auth.uid)
          || (isAuth() && get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.customerId == request.auth.uid);

        allow create: if isCoordinator()
          || (isCarrier() && get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.carrierId == request.auth.uid);

        allow update, delete: if isCoordinator();
      }

      // Learned route segments from carrier deviation/shortcut feedback
      match /routeLearnedSegments/{segmentId} {
        allow read: if isCoordinator()
          || (isAuth() && get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.carrierId == request.auth.uid)
          || (isAuth() && get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.customerId == request.auth.uid);

        allow create: if isCoordinator()
          || (isCarrier() && get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.carrierId == request.auth.uid);

        allow update, delete: if isCoordinator();
      }
    }

    // ==================== ORDERS COLLECTION ====================
    // Order records (if used separately from deliveries)
    match /orders/{orderId} {
      
      // COORDINATOR: Full access
      allow read, write: if isCoordinator();
      allow create: if isCoordinator();
      allow update: if isCoordinator();
      
      // CARRIER: Read orders
      allow read: if isCarrier();
      
      // CUSTOMER: Read own orders
      allow read: if isCustomer() && resource.data.customerId == request.auth.uid;
      
      // CUSTOMER: Create own orders
      allow create: if isCustomer() && request.resource.data.customerId == request.auth.uid;
    }

    // ==================== COORDINATORS COLLECTION ====================
    // Coordinator profile and settings
    match /coordinators/{coordinatorId} {
      
      // COORDINATOR: Read/write own profile
      allow read, write: if isCoordinator() && request.auth.uid == coordinatorId;
      
      // COORDINATOR: Read other coordinators
      allow read: if isCoordinator();
    }

    // ==================== CARRIERS COLLECTION ====================
    // Carrier profile details
    match /carriers/{carrierId} {
      
      // CARRIER: Read/write own profile
      allow read, write: if isCarrier() && request.auth.uid == carrierId;
      
      // COORDINATOR: Read all carriers
      allow read: if isCoordinator();
    }

    // ==================== CUSTOMERS COLLECTION ====================
    // Customer profile details
    match /customers/{customerId} {
      
      // CUSTOMER: Read/write own profile
      allow read, write: if isCustomer() && request.auth.uid == customerId;
      
      // COORDINATOR: Read all customers
      allow read: if isCoordinator();
    }

    // ==================== KNOWN LOCATIONS COLLECTION ====================
    // Canonical pickup/drop-off locations curated by coordinators and customers
    match /knownLocations/{locationId} {
      // COORDINATOR: full access for reading/saving curated locations
      allow read, write: if isCoordinator();
      allow create, update, delete: if isCoordinator();

      // CUSTOMER: read all known locations (for autocomplete suggestions)
      allow read: if isCustomer();

      // CUSTOMER: create new locations (saves custom pickup/dropoff names)
      allow create: if isCustomer() && request.resource.data.createdBy == request.auth.uid;

      // CUSTOMER: increment usageCount on known locations
      allow update: if isCustomer()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount', 'updatedAt']);

      // CARRIER: read known locations (for route awareness)
      allow read: if isCarrier();
    }

    // ==================== BUSINESS CONFIGURATION ====================
    // Tunable pricing/recommendation constants used by order/recommendation engines
    match /businessConfig/{configId} {
      // All authenticated app users can read current business rules
      allow read: if isAuth();

      // Coordinators own business strategy tuning controls
      allow create, update: if isCoordinator()
        && configId == 'orderEngine'
        && isValidBusinessRulesPayload(request.resource.data);

      allow delete: if isCoordinator() && configId == 'orderEngine';
    }

    // ==================== NOTIFICATIONS COLLECTION ====================
    // User-facing notifications (customer portal + coordinator tooling)
    match /notifications/{notificationId} {
      // Owner can read notifications addressed to them, coordinators can read all
      allow read: if isCoordinator()
        || (isAuth() && resource.data.userId == request.auth.uid);

      // Coordinators and carriers can create notifications for users
      // Customers may create only self-addressed notifications (dev/sample flows)
      allow create: if isCoordinator()
        || isCarrier()
        || (isCustomer() && request.resource.data.userId == request.auth.uid);

      // Owner can mark own notification read, coordinators can update all
      allow update: if isCoordinator()
        || (isAuth()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId);

      // Prevent clients from deleting notification records directly
      allow delete: if false;
    }

    // ==================== ROUTE NETWORK SEGMENTS ====================
    // Shared route governance overlays (shortcuts, blocked paths, restrictions)
    match /routeNetworkSegments/{segmentId} {
      // Used across coordinator/carrier/customer maps
      allow read: if isAuth();

      // Coordinator curates and governs the route network
      allow create, update, delete: if isCoordinator();
    }

    // ==================== ROUTE REPORTS ====================
    // Reports/suggestions from carriers and coordinators for route intelligence
    match /routeReports/{reportId} {
      // Coordinator can review all reports
      allow read: if isCoordinator();

      // Carrier can submit report only for own assigned delivery
      allow create: if isCarrier()
        && request.resource.data.source == 'carrier'
        && request.resource.data.deliveryId is string
        && get(/databases/$(database)/documents/deliveries/$(request.resource.data.deliveryId)).data.carrierId == request.auth.uid;

      // Coordinator can submit admin/coordinator-generated reports
      allow create: if isCoordinator();

      // Coordinator controls moderation workflow and lifecycle updates
      allow update, delete: if isCoordinator();
    }

    // ==================== LOCATION GRAPH — NODES ====================
    // Persistent location nodes (pickup, dropoff, carrier_current, delivery_current, hub, etc.)
    // Written by coordinator assignment logic; read by coordinator, carrier, and customer for
    // route optimization, visualization, and analytics.
    match /locationNodes/{nodeId} {
      // Read: authenticated roles can consume graph intelligence
      allow read: if isCoordinator() || isCarrier() || isCustomer();

      // Coordinator: full lifecycle management
      allow create, update, delete: if isCoordinator();

      // Carrier: constrained writes only
      // - Carrier node must belong to self
      // - Delivery node must include deliveryId and belong to carrier-assigned delivery
      allow create, update: if isCarrier() && (
        (
          request.resource.data.entityType == 'carrier'
          && request.resource.data.entityId == request.auth.uid
        )
        ||
        (
          request.resource.data.entityType == 'delivery'
          && request.resource.data.deliveryId is string
          && get(/databases/$(database)/documents/deliveries/$(request.resource.data.deliveryId)).data.carrierId == request.auth.uid
        )
      );
    }

    // ==================== LOCATION GRAPH — EDGES ====================
    // Road-distance / cost edges between location node pairs.
    // Source of truth for optimization scores, travel time, and fuel estimates.
    match /locationNodeEdges/{edgeId} {
      // Read: authenticated roles can consume graph intelligence
      allow read: if isCoordinator() || isCarrier() || isCustomer();

      // Coordinator: full lifecycle management
      allow create, update, delete: if isCoordinator();

      // Carrier: constrained write for own assigned delivery graph edges only
      allow create, update: if isCarrier()
        && request.resource.data.deliveryId is string
        && get(/databases/$(database)/documents/deliveries/$(request.resource.data.deliveryId)).data.carrierId == request.auth.uid;
    }

    // ==================== DEFAULT DENY ====================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
